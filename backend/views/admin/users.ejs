<%- include('../partials/header') %>
<link rel="stylesheet" href="/style/style-admin.css">
<div class="top-admin">
    <h1>Gerenciar Administradores</h1>
    <div class="user-info">
        <img src="/<%= user.foto %>" alt="Foto de <%= user.nome %>" class="foto-admin">
        <div>
            <small><%= user.email %></small>
        </div>
    </div>
</div>

<main>
    <% if (message) { %>
        <p class="sucesso"><%= message %></p>
    <% } %>
    <a href="/admin/usuarios/add" class="botao-adicionar">+ Adicionar Novo Administrador</a>
    <div class="grid-container">
        <% usuarios.forEach(usuario => { %>
            <div class="grid-item">
                <img src="/<%= usuario.foto %>" alt="<%= usuario.nome %>" width="100" style="border-radius:50%; margin-bottom:10px;">
                <h3><%= usuario.nome %></h3>
                <p><%= usuario.email %></p>
                <a href="/admin/usuarios/edit/<%= usuario.id %>" class="botao-editar">Editar</a>
                <a href="/admin/usuarios/delete/<%= usuario.id %>" class="botao-excluir" onclick="return confirm('Tem certeza que deseja excluir este usuário?')">Excluir</a>
            </div>
        <% }) %>
    </div>
</main>

<%- include('../partials/footer') %>